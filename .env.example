# FeltSide server environment — copy to server/.env

# Supabase Postgres connection string (Dashboard → Settings → Database).
# Use the session pooler URL. This is the service-role-equivalent direct
# DB credential; treat it like a secret.
SUPABASE_DB_URL=postgres://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:5432/postgres

# Auth
JWT_SECRET=change-me-long-random-string
JWT_EXPIRES_IN=12h

# Coach account, seeded on first boot (M1 §3)
COACH_EMAIL=coach@example.com
COACH_INITIAL_PASSWORD=change-me-strong
COACH_DISPLAY_NAME=Jo

# Server
PORT=3001
CLIENT_ORIGIN=http://localhost:5173

# CRM integration (CONTRACT §2) — the one static export/sync API key.
# Generate: openssl rand -hex 32. Give the same value to the CRM settings.
EXPORT_API_KEY=change-me-long-random-key

# Public base for exported review_url deep links (CONTRACT §4.4).
# In production this is the Fly app URL; locally the server port is fine.
PUBLIC_BASE_URL=http://localhost:3001
